javascript:(function(){if(document.getElementById("hazeyUI"))return;let state={enabled:false,invert:1,blur:0,brightness:1,contrast:1,hue:0,min:false};const ui=document.createElement("div");ui.id="hazeyUI";ui.style="position:fixed;top:20px;right:20px;width:260px;background:#111;color:#fff;font-family:sans-serif;border-radius:12px;box-shadow:0 0 15px rgba(0,0,0,0.5);z-index:999999;padding:0;overflow:hidden;";const header=document.createElement("div");header.style="display:flex;justify-content:space-between;align-items:center;padding:10px;cursor:move;background:#1a1a1a;";const title=document.createElement("b");title.textContent="EZ UI";const controls=document.createElement("div");const minBtn=document.createElement("button");minBtn.textContent="▲▼";minBtn.style="margin-right:5px;background:#333;color:#fff;border:none;border-radius:6px;cursor:pointer;padding:2px 6px;";const closeBtn=document.createElement("button");closeBtn.textContent="Destroy UI";closeBtn.style="background:red;color:white;border:none;border-radius:6px;cursor:pointer;padding:2px 6px;";controls.appendChild(minBtn);controls.appendChild(closeBtn);header.appendChild(title);header.appendChild(controls);const content=document.createElement("div");content.style="padding:12px;";function makeBtn(label,values,key){const btn=document.createElement("button");let i=0;btn.textContent=label+": "+values[i];btn.style="width:100%;margin-bottom:6px;padding:6px;border:none;border-radius:6px;background:#333;color:#fff;cursor:pointer;";btn.onclick=()=>{i=(i+1)%values.length;state[key]=values[i];btn.textContent=label+": "+values[i];apply();};return btn;}const toggleBtn=document.createElement("button");toggleBtn.textContent="Enable";toggleBtn.style="width:100%;padding:8px;margin-bottom:10px;border:none;border-radius:8px;background:#444;color:white;cursor:pointer;";toggleBtn.onclick=function(){state.enabled=!state.enabled;toggleBtn.textContent=state.enabled?"Disable":"Enable";apply();};content.appendChild(toggleBtn);content.appendChild(makeBtn("Invert",[0,1],"invert"));content.appendChild(makeBtn("Blur",[0,2,5,10],"blur"));content.appendChild(makeBtn("Brightness",[0.8,1,1.2,1.5],"brightness"));content.appendChild(makeBtn("Contrast",[0.8,1,1.2,1.5],"contrast"));content.appendChild(makeBtn("Hue",[0,90,180,270],"hue"));function apply(){if(!state.enabled){document.documentElement.style.filter="";document.querySelectorAll("img,video").forEach(el=>el.style.filter="");return;}let f=%60invert(${state.invert}) blur(${state.blur}px) brightness(${state.brightness}) contrast(${state.contrast}) hue-rotate(${state.hue}deg)%60;document.documentElement.style.filter=f;document.querySelectorAll("img,video").forEach(el=>el.style.filter="invert("+state.invert+")");}minBtn.onclick=function(){state.min=!state.min;if(state.min){content.style.display="none";minBtn.textContent="▲▼";}else{content.style.display="block";minBtn.textContent="▲▼";}};closeBtn.onclick=function(){document.documentElement.style.filter="";document.querySelectorAll("img,video").forEach(el=>el.style.filter="");ui.remove();};let isDragging=false,offsetX=0,offsetY=0;header.onmousedown=function(e){isDragging=true;offsetX=e.clientX-ui.offsetLeft;offsetY=e.clientY-ui.offsetTop;document.body.style.userSelect="none";};document.addEventListener("mousemove",function(e){if(isDragging){ui.style.left=(e.clientX-offsetX)+"px";ui.style.top=(e.clientY-offsetY)+"px";ui.style.right="auto";}});document.addEventListener("mouseup",function(){isDragging=false;document.body.style.userSelect="";});ui.appendChild(header);ui.appendChild(content);document.body.appendChild(ui);})();
