javascript:(function(){if(document.getElementById("fontForcerUI"))return;const fonts=["Arial","Verdana","Tahoma","Trebuchet MS","Times New Roman","Georgia","Garamond","Courier New","Impact","Comic Sans MS","Monospace","Sans-serif","Serif","Mojangles"];const ui=document.createElement("div");ui.id="fontForcerUI";ui.style="position:fixed;top:20px;right:20px;background:#111;color:#0f0;padding:10px;z-index:999999;font-family:monospace;border:2px solid #0f0;border-radius:8px;box-shadow:0 0 10px #0f0;width:210px;";ui.innerHTML='<div id="header" style="cursor:move;font-weight:bold;margin-bottom:5px;display:flex;justify-content:space-between;align-items:center;"><span>Font Forcer</span><span><button id="minBtn" style="margin-right:3px;">—</button><button id="closeBtn">❌</button></span></div><div id="content"><select id="fontSelect" style="width:100%;margin-bottom:5px;"></select><div style="font-size:10px;">Letter Spacing</div><input id="letterSlider" type="range" min="-5" max="10" value="0" style="width:100%;margin-bottom:5px;"><div style="font-size:10px;">Line Height</div><input id="lineSlider" type="range" min="0.5" max="3" step="0.1" value="1.2" style="width:100%;margin-bottom:5px;"><button id="resetFont" style="width:100%;">Reset</button></div>';document.body.appendChild(ui);const select=ui.querySelector("#fontSelect");fonts.forEach(f=>{const opt=document.createElement("option");opt.value=f;opt.textContent=f;select.appendChild(opt);});let styleTag=document.createElement("style");styleTag.id="fontForcerStyle";document.head.appendChild(styleTag);let mcFontLoaded=false;function loadMojangles(){if(mcFontLoaded)return;const link=document.createElement("link");link.rel="stylesheet";link.href="https://fonts.cdnfonts.com/css/minecraft-4";document.head.appendChild(link);mcFontLoaded=true;}function applyStyles(){let font=select.value;if(font==="Mojangles"){loadMojangles();font="'Minecraft', monospace";}let letter=document.getElementById("letterSlider").value;let line=document.getElementById("lineSlider").value;styleTag.innerHTML="*{font-family:"+font+" !important;letter-spacing:"+letter+"px !important;line-height:"+line+" !important;}";}function resetStyles(){if(styleTag)styleTag.innerHTML="";}select.onchange=applyStyles;document.getElementById("letterSlider").oninput=applyStyles;document.getElementById("lineSlider").oninput=applyStyles;ui.querySelector("#resetFont").onclick=resetStyles;document.getElementById("closeBtn").onclick=function(){resetStyles();ui.remove();};let minimized=false;document.getElementById("minBtn").onclick=function(){const content=document.getElementById("content");minimized=!minimized;content.style.display=minimized?"none":"block";};let isDragging=false,offsetX,offsetY;document.getElementById("header").onmousedown=e=>{isDragging=true;offsetX=e.clientX-ui.offsetLeft;offsetY=e.clientY-ui.offsetTop;};document.onmousemove=e=>{if(isDragging){ui.style.left=e.clientX-offsetX+"px";ui.style.top=e.clientY-offsetY+"px";ui.style.right="auto";}};document.onmouseup=()=>isDragging=false;})();
